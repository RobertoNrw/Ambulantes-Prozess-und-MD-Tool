# Infinite Canvas API Configuration

# API Key für Schreibzugriffe (optional, aber empfohlen für Production)
API_KEY=your-secure-random-key-here

# Erlaubte Origins für CORS (kommagetrennt)
ALLOWED_ORIGINS=https://deinedomain.com,https://www.deinedomain.com

# Optional: Data Directory anpassen
# DATA_DIR=/var/www/canvas/data
